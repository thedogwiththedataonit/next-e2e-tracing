# =============================================================================
# next-app — environment variables
# =============================================================================
#
# This is a template. To use it locally:
#
#   cp .env.example .env.local
#   # then fill in real values
#
# For Vercel preview/prod, configure each variable in the Next.js Vercel
# project's "Environment Variables" UI (or `vercel env add`). Pull them
# locally with `vercel env pull .env.local`.
#
# IMPORTANT — anything prefixed with `NEXT_PUBLIC_*` is inlined into the
# client JS bundle at build time. NEVER put a server secret behind that
# prefix. Server-only secrets (API keys, etc.) must use a plain name.
#
# The Flask API runs as a SEPARATE Vercel project. The "flask-api project"
# section at the bottom of this file documents the env vars to configure on
# THAT project — none of those vars are read by next-app.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Flask API connection (server-side)
# -----------------------------------------------------------------------------

# Full URL of the deployed Flask API, with scheme. A trailing slash is
# tolerated (the route strips it), but the `https://` is required — Node's
# `fetch` rejects URLs without a scheme.
#
# Used by `app/api/call/route.ts`. The route runs inside a Vercel Function,
# so this fetch is server-to-server (no CORS involved). `@vercel/otel`
# auto-instruments the call and injects a W3C `traceparent` header that the
# Flask side accepts via DD_TRACE_PROPAGATION_STYLE=tracecontext, joining
# both services into one Datadog APM trace.
FLASK_API_URL=https://your-flask-api.vercel.app


# -----------------------------------------------------------------------------
# 2. Datadog — server logs (Node.js, server-only)
# -----------------------------------------------------------------------------

# Datadog API key, used by `lib/DDLogSubmission.ts` to POST structured
# server logs to the Datadog Logs v2 API. Not optional in production
# (without it, log shipping silently no-ops with a warning).
#
# Server-only — never expose as NEXT_PUBLIC_*.
DD_API_KEY=your-datadog-api-key-here

# Optional. Datadog site to ship logs to.
#   - datadoghq.com   (US1, default)
#   - us3.datadoghq.com / us5.datadoghq.com
#   - datadoghq.eu    (EU)
#   - ap1.datadoghq.com (APAC)
#   - ddog-gov.com    (US gov)
# DATADOG_SITE=datadoghq.com


# -----------------------------------------------------------------------------
# 3. Datadog — Browser RUM (client-side)
# -----------------------------------------------------------------------------
# Read by `instrumentation-client.ts`, which calls `datadogRum.init()` with
# the `@datadog/browser-rum-nextjs` plugin on every client load before
# React mounts.
#
# All four REQUIRED vars below must be set, or RUM init is skipped (and a
# console warning is logged) — placeholder strings will never reach Datadog.

# Required. The RUM application ID from Datadog UI:
#   Datadog → UX Monitoring → RUM Applications → <your app> → Application ID
NEXT_PUBLIC_DATADOG_APPLICATION_ID=your-rum-application-id

# Required. The RUM client token from the same page (NOT the API key — the
# API key is server-only above).
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=your-rum-client-token

# Required. The `service` tag attached to every RUM event. Convention:
# kebab-case, matches the service name you'd want to see in Datadog APM.
NEXT_PUBLIC_DATADOG_SERVICE_NAME=next-app

# Required. The `env` tag — controls which environment your sessions show
# up under in the Datadog UI filters.
#   Suggested values: prod | preview | dev | local
NEXT_PUBLIC_DATADOG_ENV=dev

# Optional. Override the Datadog intake site. Defaults to "datadoghq.com".
# Must match the site of `DATADOG_SITE` if both are set.
# NEXT_PUBLIC_DATADOG_SITE=datadoghq.com

# Optional. Used to split RUM metrics by deploy in Datadog dashboards.
# If unset, falls back to NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA, which Vercel
# populates automatically on every build.
# NEXT_PUBLIC_DATADOG_VERSION=1.0.0

# Optional. Comma-separated list of additional origins (or URL prefixes)
# that the browser RUM SDK should inject the W3C `traceparent` header onto.
#
# Same-origin (`window.location.origin`) is always included, so the default
# proxy-via-/api/call pattern works without setting this. Add the Flask
# origin here ONLY if you change `FlaskApiClient.tsx` to call Flask directly
# from the browser — and remember CORS will then also be required on the
# Flask side.
#
# Each entry is matched as a URL prefix. Trailing slashes are stripped.
# NEVER use `*` — that leaks trace IDs to third-party domains.
# NEXT_PUBLIC_DATADOG_ALLOWED_TRACING_URLS=https://your-flask-api.vercel.app


# =============================================================================
# flask-api project — environment variables (FYI, set on the OTHER Vercel project)
# =============================================================================
# These are NOT consumed by next-app; they are the env vars you should
# configure on the flask-api Vercel project so end-to-end tracing works.
#
# DD_API_KEY=<same Datadog API key as above>
# DD_SITE=datadoghq.com
# DD_ENV=prod                            # or `preview` / `dev`
# DD_SERVICE=flask-api
# DD_VERSION=$VERCEL_GIT_COMMIT_SHA
# DD_TRACE_ENABLED=true
# DD_TRACE_PROPAGATION_STYLE=tracecontext  # CRITICAL — accepts traceparent
# DD_TRACE_OTEL_ENABLED=true               # if Flask emits OTel spans
#
# CORS: only required if the BROWSER calls Flask directly. The default
# proxy-via-/api/call pattern in this repo does not need CORS. The actual
# variable name depends on your Flask CORS setup (e.g. with `flask-cors`,
# whatever you read into `CORS(app, origins=os.environ["..."])`).
# ALLOWED_ORIGIN=https://your-next-app.vercel.app
